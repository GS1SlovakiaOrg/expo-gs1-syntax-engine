    "prepare": "node internal/module_scripts/prepare.js",
    "open:ios": "node internal/module_scripts/open-ios.js",
    "open:android": "node internal/module_scripts/open-android.js"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-gs1-syntax-engine",
    "ExpoGs1SyntaxEngine",
    "GS1 Slovakia",
    "GS1",
    "GS1 standards"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GS1SlovakiaOrg/expo-gs1-syntax-engine.git"
  },
  "bugs": {
    "url": "https://github.com/GS1SlovakiaOrg/expo-gs1-syntax-engine/issues"
  },
  "author": "Viliam <info@gs1sk.org> (https://github.com/GS1SlovakiaOrg)",
  "license": "MIT",
  "homepage": "https://github.com/GS1SlovakiaOrg/expo-gs1-syntax-engine#readme",
  "dependencies": {
    "react": "19.2.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.2.4",
    "babel-preset-expo": "~57.0.0",
    "eslint": "~9.39.4",
    "eslint-config-universe": "^15.0.3",
    "expo": "~57.0.8",
    "prettier": "^3.0.0",
    "react-native": "0.86.0",
    "typescript": "~6.0.3"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
